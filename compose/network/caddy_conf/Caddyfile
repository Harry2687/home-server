{
	# Global options
	order crowdsec first
	crowdsec {
		api_url http://crowdsec:8080
		api_key {env.CROWDSEC_API_KEY}
	}
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

# Reusable security headers
(common_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
	}
}

# Geoblocking for Cloudflare (AU only)
(geoblock) {
	@notAU {
		header CF-IPCountry *
		not header CF-IPCountry AU
	}
	respond @notAU "Access denied" 403
}

# CrowdSec snippet
(crowdsec) {
	crowdsec
}

# Snippet for harryzhong.com (Internal)
(internal_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN_INTERNAL}
	}
}

# Snippet for new/public domains
(public_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN_PUBLIC}
	}
}

jellyfin.harrys-lab.com {
	log
	import geoblock
	import common_headers
	import public_tls
	import crowdsec
	reverse_proxy jellyfin:8096
}

